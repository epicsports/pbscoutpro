# Firebase config — get these from Firebase Console → Project Settings → Your App
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000:web:000

# Sentry error tracking (optional — DSN hardcoded in sentry.js as fallback)
VITE_SENTRY_DSN=https://YOUR_KEY@oXXX.ingest.region.sentry.io/PROJECT_ID
