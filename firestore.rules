rules_version = '2';

// ─── PbScoutPro Firestore rules v2 (§ 38.9) ─────────────────────────────
// Multi-role authorization: `workspace.userRoles[uid]` is an array of
// ['admin', 'coach', 'scout', 'viewer', 'player']. Workspace admin is granted
// via 4 paths (§ 66.2 / § 67): role array, workspace.adminUid, or super_admin
// (users/{uid}.globalRole === 'super_admin' OR the bootstrap email allowlist).
//
// Rollback: firestore.rules.backup holds the pre-§38 ruleset. See
// docs/archive/cc-briefs/CC_BRIEF_SECURITY_ROLES_V2.md § "Commit 4".
//
// NOTE on self-log playerId claim: rules only verify `source == 'self'` and
// `scoutedBy == auth.uid`. The client-supplied `playerId` field is NOT
// cross-checked against the server's uid→player mapping — workspace members
// are invited, attack surface contained. Full server validation deferred.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function wsData(slug) {
      return get(/databases/$(database)/documents/workspaces/$(slug)).data;
    }
    function rolesOf(slug, uid) {
      let data = wsData(slug);
      return data.userRoles[uid];
    }
    function hasRoleIn(roles, target) {
      return roles is list && target in roles;
    }
    // Bootstrap super-admin allowlist (§ 66.2 / § 67) — the platform owner is
    // never locked out, even before the Phase 3.a globalRole migration.
    // Mirrors ADMIN_EMAILS in src/utils/roleUtils.js. The ONE place the
    // hardcoded email lives — every other site calls isSuperAdmin().
    function isBootstrapAdmin() {
      return request.auth != null
          && request.auth.token.email == 'jacek@epicsports.pl';
    }
    // Cross-workspace super_admin (§ 65.1 / § 66.2) — the explicit
    // users/{uid}.globalRole field (Phase 3.a) OR the bootstrap allowlist.
    // exists() guards the get() against a missing /users/ doc.
    function isSuperAdmin() {
      return isBootstrapAdmin()
          || (request.auth != null
              && exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'super_admin');
    }
    // Workspace admin — 4 paths (§ 66.2): workspace role 'admin', the
    // adminUid pointer, OR super_admin (cross-workspace, evaluated first so
    // the bootstrap owner short-circuits with zero document reads).
    function isAdmin(slug) {
      let uid = request.auth.uid;
      return isSuperAdmin()
          || (request.auth != null && (
               hasRoleIn(rolesOf(slug, uid), 'admin')
            || wsData(slug).adminUid == uid
          ));
    }
    // Workspace-admin (non-super) of a specific workspace — the adminUid
    // pointer (§ 65.2 / § 67). Used by the Phase 3.c.2 ownership gates on
    // global /teams/ + /players/. Distinct from isAdmin(slug): no
    // super_admin short-circuit and no role-array path. `slug is string`
    // guards exists()/get() when ownerWorkspaceId is missing on a doc.
    function isWorkspaceAdminOf(slug) {
      return request.auth != null
          && slug is string
          && exists(/databases/$(database)/documents/workspaces/$(slug))
          && get(/databases/$(database)/documents/workspaces/$(slug)).data.adminUid == request.auth.uid;
    }
    function isCoach(slug) {
      return isAdmin(slug) || hasRoleIn(rolesOf(slug, request.auth.uid), 'coach');
    }
    function isScout(slug) {
      return isCoach(slug) || hasRoleIn(rolesOf(slug, request.auth.uid), 'scout');
    }
    function isPlayer(slug) {
      return request.auth != null && hasRoleIn(rolesOf(slug, request.auth.uid), 'player');
    }
    function isMember(slug) {
      let data = wsData(slug);
      return request.auth != null
          && data.members is list
          && request.auth.uid in data.members;
    }
    // Note: no isViewer() helper — viewer reads are covered by isMember();
    // a dedicated helper lands in Phase 3.c.2 with its first match-block
    // consumer (an unused rules function emits a compiler warning).
    // gap α (§ 49.10) — self-log shot `playerId` cross-check. The pre-fix
    // helpers checked source + scoutedBy but NOT playerId, letting a PLAYER-
    // role direct-SDK writer attribute a self-log shot to ANOTHER player.
    // Discovery (2026-05-27) verified: the only canonical writer hitting
    // these helpers is MatchPage.handleSelfLogSave with playerId = own linked
    // player id (selfPlayerId = linkedPlayer?.id, MatchPage.jsx:393). KIOSK
    // + post-hoc propagator + PPT all ride isScout / a different collection,
    // so they're unaffected by tightening these PLAYER-disjunct helpers.
    //
    // playerId namespace: GLOBAL /players/{id} (subscribeLinkedPlayer queries
    // collection(db, 'players') per § 85 B2(c)) — same lookup target as the
    // existing isLinkedSelfPlayer helper.
    //
    // Brittle-null guard `data.get('linkedUid', null)` per § 85 B2(c) covers
    // missing AND explicit-null linkedUid (addPlayer / CSVImport historically
    // created docs without the field at all).
    function isSelfLogShotCreate(slug) {
      return isPlayer(slug)
          && request.resource.data.source == 'self'
          && request.resource.data.scoutedBy == request.auth.uid
          && exists(/databases/$(database)/documents/players/$(request.resource.data.playerId))
          && get(/databases/$(database)/documents/players/$(request.resource.data.playerId))
                .data.get('linkedUid', null) == request.auth.uid;
    }
    function isSelfLogShotOwned(slug) {
      return isPlayer(slug)
          && resource.data.source == 'self'
          && resource.data.scoutedBy == request.auth.uid
          && exists(/databases/$(database)/documents/players/$(resource.data.playerId))
          && get(/databases/$(database)/documents/players/$(resource.data.playerId))
                .data.get('linkedUid', null) == request.auth.uid;
    }
    // § 49 follow-up (rules audit gap #2, 2026-05-23) — selfReports cross-pid
    // tighten: a player may only act on their own linked player's selfReports.
    // The pid path segment is checked against the player doc's linkedUid.
    // exists() guards the get() if a stale path is supplied. Brittle-null
    // canonical form (data.get('linkedUid', null)) matches the player
    // self-link rule below — covers missing AND explicit-null cases.
    //
    // § 85 B2 (c) — helper now reads GLOBAL `/players/{pid}` (was workspace).
    // Pairs with the link-ops migration in dataService. The slug param is
    // retained so the existing call sites (workspace selfReports rule at the
    // /workspaces/{slug}/players/{pid}/selfReports/ subtree) keep passing it
    // for the isPlayer(slug) workspace-role check; ONLY the linkedUid lookup
    // target moves to global.
    function isLinkedSelfPlayer(slug, pid) {
      return isPlayer(slug)
          && exists(/databases/$(database)/documents/players/$(pid))
          && get(/databases/$(database)/documents/players/$(pid)).data.get('linkedUid', null) == request.auth.uid;
    }
    // gap β (§ 49.11) — self-write-role value-check. The self-join + self-leave
    // envelopes both list `userRoles` in their affectedKeys allow-list (so the
    // map can be touched), but neither constrains the VALUE. A direct-SDK
    // writer could bypass the client and set `userRoles[self] = ['admin']`.
    // Canonical client only ever writes [] (pending) or ['player'] (auto-
    // approved default workspace) — see useWorkspace.jsx:209/212. This helper
    // enforces that envelope.
    function isSelfJoinRoleValue(r) {
      return r is list && (r.size() == 0 || r == ['player']);
    }
    // Model B invite redemption — fetch an invite doc by token.
    function inviteData(token) {
      return get(/databases/$(database)/documents/invites/$(token)).data;
    }

    // ─── Users (global profiles) ─────────────────────────────────────
    // Tier B hardening (2026-04-25): replaced unrestricted `allow write` with
    // explicit create + scoped update. Self-update is allow-listed to the
    // three fields the client legitimately writes (displayName/email from
    // ProfilePage + linkSkippedAt from skipLinkOnboarding). This closes the
    // soft-delete bypass — users can no longer self-clear `disabled` via
    // SDK to re-enable themselves after admin softDisableUser. Other
    // admin-managed fields (roles, defaultWorkspace, workspaces) also
    // become create-only — set once at signup, mutated by admin only.
    // Delete is implicit-deny (no allow-rule); user docs can't be self-deleted.
    match /users/{uid} {
      allow read: if request.auth != null;
      // gap β sibling (2026-05-27 follow-up) — defense-in-depth value check
      // at create time. The canonical client writer (`getOrCreateUserProfile`
      // in `services/dataService.js`) sets `roles: ['player']` and never
      // writes `globalRole` at signup. A direct-SDK actor bypassing the
      // client could have set `roles: ['admin']` or `globalRole: 'super_admin'`
      // on their own `/users/{uid}` doc — workspace-side gap β stops the
      // direct PE path (self-join envelope value gate), but tightening here
      // closes the upstream hole before workspace #2 onboarding. The
      // update-side allow-lists (L141, L148) already exclude `roles` and
      // `globalRole` from self-update + super_admin soft-disable, so these
      // fields are write-once at create (or set by admin SDK migrations,
      // which bypass rules entirely).
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && (request.resource.data.get('roles', []) == []
                        || request.resource.data.get('roles', []) == ['player'])
                    && request.resource.data.get('globalRole', null) == null;
      // Self-update — narrow allow-list. ADD a field here if a new
      // legitimate self-write client path is introduced; missing one
      // results in silent permission-denied at runtime.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'email', 'linkSkippedAt']);
      // Admin soft-disable (§ 50.5) — super_admin only (globalRole or the
      // bootstrap allowlist, via isSuperAdmin — § 66.2 / § 67), scoped to
      // the disabled-flag fields.
      allow update: if isSuperAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['disabled', 'disabledAt', 'disabledBy', 'reEnabledAt']);

      // Per-user app state (Packing Checklist + future per-user prefs) — owner-only.
      // STAGED 2026-06-17 (CC_BRIEF_PACKING_CHECKLIST Stage D). NOT YET DEPLOYED —
      // deploy with Jacek's morning GO (`firebase deploy --only firestore:rules`).
      // Until deployed, the client read/write degrades silently to in-memory.
      match /appState/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ─── Collection-group read: selfReports (PPT, § 48 · § read-volume C 2) ──
    // Coach/PPT reads (getEventShotFrequencies, getTrainingSelfReports) sweep
    // selfReports filtered by workspaceSlug + trainingId. Collection-group
    // queries require a rule at database root matching the collection name via
    // /{path=**}/selfReports/{id}.
    //
    // § read-volume C 2 (tenant-isolation): scoped from "any authed" to workspace
    // members only. Rules-are-not-filters — every CG consumer now constrains
    // workspaceSlug (see playerPerformanceTrackerService) so this predicate is
    // query-provable. Layout-wide crowdsource reads moved to the precomputed
    // /layoutAggregates pool (1.2), so no consumer needs cross-tenant raw reads.
    match /{path=**}/selfReports/{sid} {
      allow read: if isMember(resource.data.workspaceSlug);
    }

    // ─── Collection-group read: shots (self-log · § read-volume C 2) ──────────
    // fetchSelfLogShotsForPlayer (workspaceSlug + tournamentId) is a member read;
    // usePlayerBreakoutHistory (playerLinkedUid == own uid) is a player self-read.
    // Two disjoint, query-provable branches — members see their workspace's shots;
    // a player always sees their OWN self-log shots regardless of membership.
    // Old shots lacking playerLinkedUid fall through to the isMember branch only.
    match /{path=**}/shots/{sid} {
      allow read: if isMember(resource.data.workspaceSlug)
                  || (request.auth != null
                      && resource.data.get('playerLinkedUid', null) == request.auth.uid);
    }

    // ─── Workspace root ──────────────────────────────────────────────
    match /workspaces/{slug} {
      // STAGE 3 (Model B isolation gate): full read requires membership (or
      // super_admin). Closes the cross-tenant metadata leak — members / userRoles
      // / pendingApprovals / passwordHash were readable by ANY authed user. The
      // old "authed probe" is no longer needed: invite redemption carries the
      // slug and reads the INVITE doc (not the workspace doc) as a non-member.
      //
      // §C nav drawer gate fix (2026-06-12): membership checked on
      // resource.data DIRECTLY (not the get()-based isMember(slug)) so the
      // rule is LIST-PROVABLE for the `members array-contains uid` queries
      // (useUserWorkspaces D1 + auto-enter STEP 9). The get()-based form
      // raised "Null value error" on every list → those queries were silently
      // permission-denied (switcher never showed >1 workspace for non-super-
      // admins; defaultWorkspace-less members dead-ended on NoWorkspaceScreen
      // — the 5f69dc04 regression test was red on main). For single-doc gets
      // resource.data IS the same doc isMember(slug) fetched — predicate
      // semantics unchanged, one get() cheaper. isMember's `members is list`
      // guard is dropped: it BREAKS list provability (verified vs emulator),
      // and on a missing/non-list members the `in` errors → rule false →
      // deny, the exact same outcome the guard produced.
      // ⚠ TENANT-ISOLATION PREDICATE — prod `firebase deploy --only
      // firestore:rules` requires Jacek's explicit CONFIRM (CLAUDE.md policy).
      allow read: if (request.auth != null
                      && request.auth.uid in resource.data.members)
                  || isSuperAdmin();

      // Create: authenticated user bootstraps a new workspace and must
      // include themselves in members.
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'members'])
                    && request.resource.data.members is list
                    && request.auth.uid in request.resource.data.members;

      // Update:
      //   Admin — anything (role changes, transfers, migration, etc.)
      //   Authenticated — self-join envelope only (add self to members +
      //     pendingApprovals, set own empty-roles entry, bump lastAccess).
      //     affectedKeys allow-list keeps non-admin writes narrow.
      //   Self-leave envelope (§ 50.3) — user removes themselves from
      //     members[]. Was-in-members + now-not-in-members invariant blocks
      //     mass-eviction abuse (caller can only remove THEMSELVES; the
      //     'pure removal' delta has no way to express a mutation of other
      //     members because affectedKeys is restricted to the same three
      //     fields). UI enforces last-admin guard (rules don't — would need
      //     iteration over userRoles map).
      //
      // Tier B hardening (2026-04-25): dropped `passwordHash` from the
      // self-join allow-list. Was a defense-in-depth gap — any auth user
      // could rewrite the workspace passwordHash during enterWorkspace,
      // potentially locking out future password-typed entry. Unreachable
      // in production today (ranger1996 has passwordHash set, LoginGate
      // is retired, jacek admin via email allowlist not via password) but
      // worth closing. Brand-new workspace creation still sets passwordHash
      // via `allow create` (unchanged). useWorkspace.jsx:184 fallback path
      // (`if (!data.passwordHash) update.passwordHash = pwHash`) becomes
      // unreachable for non-admin self-join — acceptable, no live workspace
      // is in that state.
      // gap β (§ 49.11) — both non-admin envelopes below gain TWO conditional
      // value/key checks on `userRoles`. Both are SHORT-CIRCUITED by the
      // `!('userRoles' in diff.affectedKeys())` first half — so returning
      // members (e.g. coach re-entry) whose write OMITS userRoles entirely
      // are unaffected. The checks fire only when userRoles actually changes:
      //   (1) value gate: self-key value must be [] or ['player'] (closes
      //       userRoles[self] = ['admin'] escalation).
      //   (2) own-key gate: only userRoles[auth.uid] may change (closes
      //       userRoles[OTHER-UID] = ['admin'] confederate escalation).
      // Own-key gate is safe because PRE-FLIGHT confirmed client writes are
      // SELF-KEY-ONLY (setDoc(merge:true) + updateDoc dot-path; verified
      // against useWorkspace.jsx:209/212 + dataService.removeMember L1872).
      // STAGE 3 (Model B isolation gate): the open SELF-JOIN branch was REMOVED
      // here — a non-member can no longer add themselves to members/userRoles.
      // Membership is now admin-granted or invite-redeemed only, which closes the
      // cross-tenant read hole (isMember was true for any self-joiner). Remaining
      // non-admin branches: self-LEAVE (remove self) + invite-grant (Stage 2).
      allow update: if isAdmin(slug)
                    || (
                      request.auth != null
                      && request.auth.uid in resource.data.members
                      && !(request.auth.uid in request.resource.data.members)
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['members', 'userRoles', 'pendingApprovals'])
                      && ( !('userRoles' in request.resource.data.diff(resource.data).affectedKeys())
                           || isSelfJoinRoleValue(request.resource.data.userRoles[request.auth.uid]) )
                      && ( !('userRoles' in request.resource.data.diff(resource.data).affectedKeys())
                           || request.resource.data.userRoles.diff(resource.data.userRoles)
                                .affectedKeys().hasOnly([request.auth.uid]) )
                    )
                    || (
                      // Model B invite-grant (Stage 2) — invitee self-adds to
                      // members with the invite's role, validated against the
                      // invite this batch is redeeming (lastRedeemedInviteToken).
                      // The invite's unredeemed gate + this committed-state get()
                      // make it one-shot. STAGE 3 removes the two self-join
                      // branches above, leaving admin + this as the only
                      // membership writes (closes the cross-tenant self-join hole).
                      request.auth != null
                      && !(request.auth.uid in resource.data.members)
                      && request.auth.uid in request.resource.data.members
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['members', 'userRoles', 'lastAccess', 'lastRedeemedInviteToken'])
                      && request.resource.data.lastRedeemedInviteToken is string
                      && exists(/databases/$(database)/documents/invites/$(request.resource.data.lastRedeemedInviteToken))
                      && inviteData(request.resource.data.lastRedeemedInviteToken).workspaceSlug == slug
                      && inviteData(request.resource.data.lastRedeemedInviteToken).get('redeemedBy', null) == null
                      && request.time.toMillis() < inviteData(request.resource.data.lastRedeemedInviteToken).expiresAt
                      && request.resource.data.userRoles[request.auth.uid]
                         == [inviteData(request.resource.data.lastRedeemedInviteToken).role]
                      && request.resource.data.userRoles.diff(resource.data.userRoles)
                           .affectedKeys().hasOnly([request.auth.uid])
                    )
                    || (
                      // Email-keyed self-claim (durable association, no backend):
                      // the invitee self-adds to members with the invite's role,
                      // validated against invites/{authEmail} (the committed,
                      // still-pending email-invite this batch is claiming). Keyed
                      // on the auth email → works in any browser, no token.
                      // ⚠ TENANT-ISOLATION PREDICATE — prod deploy needs Jacek CONFIRM.
                      request.auth != null
                      && request.auth.token.email_verified == true
                      // Claimant must currently have NO role: a FRESH non-member
                      // (userRoles[uid] absent → []) OR an already-member stuck in
                      // pending-approval (userRoles[uid] == [], e.g. biuro joined via
                      // the old self-join before the invite existed). Either way the
                      // claim GRANTS the invited role; it can never overwrite an
                      // existing non-empty role (the userRoles[uid] == [invite.role]
                      // + own-key-diff guards below bound the result exactly).
                      && resource.data.userRoles.get(request.auth.uid, []) == []
                      && request.auth.uid in request.resource.data.members
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['members', 'userRoles', 'lastAccess', 'lastClaimedInviteEmail'])
                      && request.resource.data.lastClaimedInviteEmail is string
                      && request.resource.data.lastClaimedInviteEmail == request.auth.token.email.lower()
                      && exists(/databases/$(database)/documents/invites/$(request.resource.data.lastClaimedInviteEmail))
                      && inviteData(request.resource.data.lastClaimedInviteEmail).workspaceSlug == slug
                      && inviteData(request.resource.data.lastClaimedInviteEmail).get('status', null) == 'pending'
                      && request.resource.data.userRoles[request.auth.uid]
                         == [inviteData(request.resource.data.lastClaimedInviteEmail).role]
                      && request.resource.data.userRoles.diff(resource.data.userRoles)
                           .affectedKeys().hasOnly([request.auth.uid])
                    );

      allow delete: if isAdmin(slug);

      // ── Feature flags + workspace config ──
      match /config/{doc} {
        allow read: if isMember(slug);
        allow write: if isAdmin(slug);
      }

      // ── Players twin REMOVED 2026-06-05 (§90 Stage 2B.3) ──
      // The read-retired /workspaces/{slug}/players/{pid} twin was decommissioned
      // (docs deleted; global /players is canonical). The only remaining live
      // writer (deletePlayer, PlayersPage roster delete) was repointed to the
      // global hard-delete (deletePlayerGlobal, super_admin-only) per Jacek's
      // decision, so the twin write paths are gone. The self-link / self-edit /
      // self-unlink carve-outs are fully served by the global /players block
      // (§85, below at the database root). breakoutVariants relocated (2A.2).

      // ── selfReports (flat path — § 90 Phase 2 Stage 1, dual-write transition) ──
      // Relocated from /workspaces/{slug}/players/{pid}/selfReports/{sid} so the
      // workspace player doc can decommission (Phase 2.2.d). Identical
      // isMember(slug) semantics. The {pid} path segment is replaced by an
      // explicit `playerId` field on the doc, which isLinkedSelfPlayer reads
      // via request.resource.data.playerId (create) / resource.data.playerId
      // (update + delete) instead of inheriting from the path. Coach catch-
      // all on update/delete mirrors the legacy block — propagator + Stage 4
      // override + dismiss flows run in the coach's session.
      //
      // Stage 1.B.3 cutover + § 90.7.3 cleanup (2026-05-28): this flat path is
      // the ONLY selfReports path now — writers create here, the legacy nested
      // /players/{pid}/selfReports/ docs were deleted and that rules block
      // removed. This is the canonical block.
      match /selfReports/{sid} {
        allow read: if isMember(slug);
        allow create: if isLinkedSelfPlayer(slug, request.resource.data.playerId);
        allow update, delete: if isCoach(slug)
                              || isLinkedSelfPlayer(slug, resource.data.playerId);
      }

      // ── PPT pending self-reports (unlinked-mode, 2026-04-24) ──
      // When a player opens PPT before linking to a player profile, their
      // logs go here instead of /players/{pid}/selfReports/{sid}. Each doc
      // carries `uid` for ownership; on link, migratePendingToPlayer moves
      // the batch into the canonical player path and deletes originals.
      //
      // Ownership — strict: create requires `uid == auth.uid` on the
      // incoming doc; read/update/delete require the existing doc's `uid`
      // to match auth. No coach visibility (unlinked logs are drafts by
      // definition). Once migrated they become regular selfReports under
      // `/players/{pid}/selfReports/` and pick up the isMember read rule.
      match /pendingSelfReports/{sid} {
        allow create: if request.auth != null
                      && isMember(slug)
                      && request.resource.data.uid == request.auth.uid;
        allow read, update, delete: if request.auth != null
                                    && isMember(slug)
                                    && resource.data.uid == request.auth.uid;
      }

      // ── Teams twin REMOVED 2026-06-05 (§90 Stage 2B) ──
      // The read-retired /workspaces/{slug}/teams/{teamId} twin was decommissioned
      // (docs deleted; global /teams is canonical). deleteTeam (the only workspace
      // teams-twin writer) is dead — TeamDetailPage uses retireTeam (global).
      // breakoutVariants was relocated to its own workspace path (2A.2, below).

      // ── Breakout variants (§ 90 cutover 2A.2 — relocated off the teams twin) ──
      // Team-level self-log variant pool, moved from /teams/{teamId}/breakoutVariants
      // to its own workspace path so the read-retired teams twin can be
      // decommissioned (Stage 2B). teamId is a path segment. Same gate as the old
      // teams-twin subcollection: read isMember, write isCoach. Workspace-local.
      match /breakoutVariants/{teamId}/{document=**} {
        allow read: if isMember(slug);
        allow write: if isCoach(slug);
      }

      // ── Layouts twin REMOVED 2026-06-05 (§90 Stage 3 / §96 cleanup) ──
      // The legacy pre-globalization /workspaces/{slug}/layouts collection was
      // emptied by the §96 migration (base → global /layouts/; zones/tactics/
      // insights → /layoutOverlays/ below) and its 5 ranger1996 stragglers were
      // deleted. The bp()/layouts CRUD (subscribeLayouts/addLayout/updateLayout/
      // deleteLayout) is dead — live UI uses addLayoutToWorkspace + overlays.

      // ── Layout overlays (§ 96 / § 98) ──
      // Per-workspace annotations on a global base layout: zones, lineDivision
      // (the 2 field-division thresholds), callout lines, bunker-name overrides,
      // naming override, + tactics/insights subcollections. Doc id == the
      // referenced global base id (so tournament.layoutId keeps resolving).
      // Isolation: workspace-local, isMember read.
      // § 98 — the overlay DOC (layout config: zones/lineDivision/lines/
      // bunkerNames/nameOverride) is local-admin-owned → write isAdmin.
      // The tactics/insights SUBCOLLECTIONS stay coach-writable (team plays).
      // The shared base geometry lives in global /layouts/ (super_admin-write).
      match /layoutOverlays/{lid} {
        allow read: if isMember(slug);
        allow write: if isAdmin(slug);
        match /{document=**} {
          allow read: if isMember(slug);
          allow write: if isCoach(slug);
        }
      }

      // ── Events index (Model C — § 69) ──
      // Thin cross-type event list. Read = any workspace member; write gated
      // scout+ (same as the parent /tournaments/ + /trainings/ collections —
      // index writes ride in the same writeBatch as the event-doc write).
      match /events_index/{eventId} {
        allow read: if isMember(slug);
        allow write: if isScout(slug);
      }

      // ── Tournaments ──
      // Scout+ writes all tournament content. Self-log shots carved out so
      // players can append own shot docs to the shots subcollection.
      match /tournaments/{tid} {
        allow read: if isMember(slug);
        allow write: if isScout(slug);

        // Self-log carve-out at /matches/{mid}/points/{pid}/shots/{sid}.
        // MUST appear before the catch-all below so it takes precedence for
        // player creates/updates.
        match /matches/{mid}/points/{pid}/shots/{sid} {
          allow read: if isMember(slug);
          allow create: if isScout(slug) || isSelfLogShotCreate(slug);
          allow update, delete: if isScout(slug) || isSelfLogShotOwned(slug);
        }

        // Catch-all for other tournament content (matches, points,
        // tactics, scouted teams, etc.) — scout+ only.
        match /{document=**} {
          allow read: if isMember(slug);
          allow write: if isScout(slug);
        }
      }

      // ── Trainings (mirror tournament structure) ──
      match /trainings/{trid} {
        allow read: if isMember(slug);
        allow write: if isScout(slug);

        // Training self-log carve-out at /matchups/{mid}/points/{pid}/shots/{sid}.
        match /matchups/{mid}/points/{pid}/shots/{sid} {
          allow read: if isMember(slug);
          allow create: if isScout(slug) || isSelfLogShotCreate(slug);
          allow update, delete: if isScout(slug) || isSelfLogShotOwned(slug);
        }

        match /{document=**} {
          allow read: if isMember(slug);
          allow write: if isScout(slug);
        }
      }
    }

    // ─── /leagues/ (global configurable resource per § 63.15.1) ──
    // Phase 2.1c CRUD via /admin/leagues UI. Read open to any auth
    // user (Phase 2.1b useLeagues hook needs unrestricted read).
    // Write gated to super_admin via isSuperAdmin() (globalRole or the
    // bootstrap allowlist, § 66.2 / § 67) — defense in depth with the
    // AdminGuard wrapper in App.jsx.
    match /leagues/{leagueId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── /invites/ (Model B controlled join) ──
    // Admin-issued join tokens replace the open self-join. `token` is the
    // secret → read open to any authed user (needed to redeem). CREATE gating:
    // super_admin may issue ANY role for ANY workspace; an admin OF the slug
    // may issue NON-admin roles for that slug only; nobody else. New invites
    // must be unredeemed. Redemption (update redeemedBy/redeemedAt) + revoke
    // (delete) land in Stage 2 / fast-follow.
    match /invites/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.workspaceSlug is string
                    && request.resource.data.role in ['admin', 'coach', 'scout', 'player']
                    && request.resource.data.get('redeemedBy', null) == null
                    && (
                         isSuperAdmin()
                      || ( isAdmin(request.resource.data.workspaceSlug)
                           && request.resource.data.role != 'admin' )
                    );
      // Redemption (Stage 2): the invitee marks it redeemed-by-self, once.
      // One-shot anchor — single doc, serialized; unredeemed + unexpired gate.
      allow update: if request.auth != null
                    && resource.data.get('redeemedBy', null) == null
                    && request.time.toMillis() < resource.data.expiresAt
                    && request.resource.data.redeemedBy == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['redeemedBy', 'redeemedAt']);
      // Email-keyed claim (durable association, no backend): the invitee whose
      // authed email matches this email-invite (doc id == email == auth email)
      // marks it claimed-by-self, once. The matching workspace membership write
      // is gated separately by the email-self-claim branch on /workspaces.
      // ⚠ TENANT-ISOLATION-ADJACENT — prod rules deploy needs Jacek CONFIRM.
      allow update: if request.auth != null
                    && request.auth.token.email_verified == true
                    && resource.data.get('status', null) == 'pending'
                    && resource.data.get('email', '') == request.auth.token.email.lower()
                    && request.resource.data.status == 'claimed'
                    && request.resource.data.claimedBy == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'claimedBy', 'claimedAt']);
    }

    // ─── /meta/ (global app metadata) ──
    // catalogVersion marker for the client catalog cache-gate: any authed user
    // reads it (1 doc) to decide whether their cached players/teams catalog is
    // current; only super_admin bumps it (CSV import completion + destructive
    // global catalog ops). Global, not tenant-scoped.
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── /players/ (global resource per § 63.15.3) ──
    // Phase 2.2.b consumption (usePlayers hook reads here, dual-write from
    // dataService writes here in parallel with the legacy workspace path).
    // Read open to any auth user.
    //
    // Phase 3.c.2 ownership gating (§ 65.2 single-owner model): create +
    // update require super_admin OR the workspace_admin of the owning
    // workspace. ownerWorkspaceId is backfilled on all docs + set by
    // addPlayer; the workspace_admin update path pins it immutable
    // (ownership transfer is super_admin-only — Phase 3.f). Delete stays
    // super_admin-only (aliasIds[] reference safety, § 63.15.3).
    //
    // § 85 B2 (c) — self-link / self-edit / self-unlink carve-outs MIRROR
    // the workspace `/players/{pid}` block (L228-270) but each is gated on
    // `isMember(resource.data.ownerWorkspaceId)` so a user can only act on
    // a player IN THEIR OWN WORKSPACE. The wider read of global /players/
    // does NOT grant cross-workspace claim ability — the carve-outs are
    // workspace-scoped via the membership check.
    //
    // Ownership-transfer guard (Phase 3.c.2): the existing structural-write
    // path pins `ownerWorkspaceId` immutable for workspace_admin. The
    // self-* carve-outs below MUST also be gated on `affectedKeys().hasOnly`
    // allow-lists that do NOT include `ownerWorkspaceId` — preserving the
    // single-owner contract.
    match /players/{playerId} {
      allow read: if request.auth != null;
      allow create: if isSuperAdmin()
                    || isWorkspaceAdminOf(request.resource.data.ownerWorkspaceId);
      allow update: if isSuperAdmin()
                    || (isWorkspaceAdminOf(resource.data.ownerWorkspaceId)
                        && request.resource.data.ownerWorkspaceId == resource.data.ownerWorkspaceId)
                    // § 85 — Self-link carve-out (workspace-scoped).
                    // Permits first-time claim (linkedUid missing OR null) AND
                    // idempotent re-claim (same uid re-runs from another device).
                    // Brittle-null canonical form: `data.get('linkedUid', null)`.
                    // Diff allow-list does NOT include `ownerWorkspaceId` —
                    // ownership-transfer guard preserved.
                    || (
                      request.auth != null
                      && isMember(resource.data.ownerWorkspaceId)
                      && (resource.data.get('linkedUid', null) == null
                          || resource.data.get('linkedUid', null) == request.auth.uid)
                      && request.resource.data.linkedUid == request.auth.uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['linkedUid', 'pbliIdFull', 'linkedAt'])
                    )
                    // § 85 — Self-edit carve-out (workspace-scoped). Linked
                    // player edits their own roster-facing identity fields
                    // via /profile → "Dane gracza". Team assignment, PBLI ID,
                    // paintball role/class, and linkedUid stay admin-only
                    // (not in the allow-list).
                    || (
                      request.auth != null
                      && isMember(resource.data.ownerWorkspaceId)
                      && resource.data.linkedUid == request.auth.uid
                      && request.resource.data.linkedUid == request.auth.uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['nickname', 'name', 'number', 'age',
                                   'favoriteBunker', 'nationality', 'updatedAt'])
                    )
                    // § 85 — Self-unlink carve-out (workspace-scoped).
                    || (
                      request.auth != null
                      && isMember(resource.data.ownerWorkspaceId)
                      && resource.data.linkedUid == request.auth.uid
                      && request.resource.data.linkedUid == null
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['linkedUid', 'pbliIdFull', 'unlinkedAt'])
                    );
      allow delete: if isSuperAdmin();
    }

    // ─── /teams/ (global resource per § 63.15.2 + § 63.15.2.X) ──
    // Phase 2.3.b consumption (useTeams hook reads here, dual-write from
    // dataService writes here in parallel with the legacy workspace path).
    // Read open to any auth user.
    //
    // Phase 3.c.2 ownership gating (§ 65.2 single-owner model): create +
    // update require super_admin OR the workspace_admin of the owning
    // workspace. ownerWorkspaceId is backfilled on all docs + set by
    // addTeam; the workspace_admin update path pins it immutable (ownership
    // transfer is super_admin-only — Phase 3.f). Delete stays super_admin-
    // only — parentTeamId children + externalId duplicates need deliberate
    // admin handling (§ 63.15.2.X).
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if isSuperAdmin()
                    || isWorkspaceAdminOf(request.resource.data.ownerWorkspaceId);
      allow update: if isSuperAdmin()
                    || (isWorkspaceAdminOf(resource.data.ownerWorkspaceId)
                        && request.resource.data.ownerWorkspaceId == resource.data.ownerWorkspaceId);
      allow delete: if isSuperAdmin();
    }

    // ─── /layouts/ (global base library per § 96) ──
    // Shared field-geometry base: bunkers, fieldImage, fieldCalibration,
    // discoLine/zeekerLine, mirrorMode/doritoSide, name/league/year. Designed
    // once, consumed by every workspace via a /workspaces/{slug}/
    // layoutOverlays/{id} doc that references this base id. Zones, zone names,
    // and tactics are NOT here — they live on the per-workspace overlay.
    //
    // Governance (§ 96, super_admin-curated): a shared base means one edit
    // affects every workspace using it → curation, NOT federation. Read = any
    // auth user (the library is browsable so coaches can add a base to their
    // workspace). Write = super_admin only — no ownerWorkspaceId / versioning
    // machinery needed because no one but the curator mutates a base.
    // NOTE: this is a shared-library predicate, NOT a tenant-isolation one
    // (isolation lives on the overlay's isMember gate) — but still a rules
    // deploy, so it ships behind the build brief's CONFIRM checkpoint.
    match /layouts/{layoutId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── /layoutAggregates/ (§ read-volume C 1.2 — crowdsource shot pool) ──
    // Precomputed cross-tenant bunker-shot frequencies per layout (replaces the
    // raw selfReports/shots collectionGroup sweep for layout-wide reads, so those
    // CGs can be tenant-scoped in Stage 2). Read = any authed (shared pool, like
    // /layouts).
    //
    // § read-volume C 2.4 — WRITE = any authed user. This is a DELIBERATE
    // cross-tenant shared-write surface: the pool is crowdsourced across all
    // workspaces, and the doc holds only additive {h,m,u} counters keyed by
    // layout bunker — no tenant-private data. Rules cannot enforce increment-only
    // on nested-map fields, so the client writes increment()-only deltas
    // (bumpLayoutAggregateFromShot / *FromSelfReport) and the aggregate is fully
    // recomputable from raw selfReports/shots (admin-SDK backfill) if poisoned.
    match /layoutAggregates/{layoutId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── /leaderboards/{board}/scores/{uid} (§117 Reads Mini "Take a Break") ──
    // ONE global arcade leaderboard (best score per account). DELIBERATE break of
    // per-workspace isolation (§117.6): recreational, no scouting data; public
    // label is a 3-letter arcade tag (no PII/GDPR). Read = any authed (top-25
    // orderBy score desc, single-field → auto-indexed, no composite). Anti-cheat:
    // own doc only, int score 0..9999, valid [A-Z]{3} initials, monotonic score,
    // 5s write cooldown, no delete. (App Check enforcement = STAGE 3, separate GO.)
    match /leaderboards/{board}/scores/{uid} {
      function validRow(d) {
        return d.uid == uid
          && d.initials is string && d.initials.matches('[A-Z]{3}')
          && d.score is int && d.score >= 0 && d.score <= 9999
          && d.mode in ['A', 'B'];
      }
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && validRow(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && validRow(request.resource.data)
        && request.resource.data.score > resource.data.score
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.time > resource.data.updatedAt + duration.value(5, 's');
      allow delete: if false;
    }
  }
}
