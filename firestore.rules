rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Workspace document ──
    match /workspaces/{slug} {
      // Anyone authenticated can read workspace (login screen check)
      allow read: if request.auth != null;

      // Anyone authenticated can create a new workspace
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'members', 'createdAt'])
                    && request.resource.data.members is list
                    && request.auth.uid in request.resource.data.members;

      // Members can update; also allow joining (adding uid to members)
      // Handles migration: old workspaces without members field
      allow update: if request.auth != null
                    && (
                      // Existing member
                      (resource.data.members is list && request.auth.uid in resource.data.members)
                      // Joining: uid being added to members (covers first join + migration)
                      || (request.resource.data.members is list && request.auth.uid in request.resource.data.members)
                    );

      // Only admin can delete
      allow delete: if request.auth != null
                    && resource.data.adminUid == request.auth.uid;

      // ── Feature flags config ──
      // All workspace members can read; only admin can write
      match /config/{doc} {
        allow read: if request.auth != null;
        // TODO: replace UID_JACEK_TBD with real UID
        allow write: if request.auth != null
                     && request.auth.uid in ['UID_JACEK_TBD'];
      }

      // ── All data inside a workspace ──
      // Only members of the workspace can read/write
      match /{document=**} {
        allow read, write: if request.auth != null
                           && get(/databases/$(database)/documents/workspaces/$(slug)).data.members is list
                           && request.auth.uid in
                              get(/databases/$(database)/documents/workspaces/$(slug)).data.members;
      }
    }
  }
}
