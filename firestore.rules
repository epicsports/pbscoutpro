rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Workspace root — anyone can read/create
    match /workspaces/{workspaceSlug} {
      allow read, write: if true;

      // All data inside a workspace is accessible to anyone with the slug
      match /{document=**} {
        allow read, write: if true;
      }
    }

    // ─── Production rules (add Firebase Auth, then uncomment) ───
    //
    // match /workspaces/{slug} {
    //   allow read: if request.auth != null;
    //   allow create: if request.auth != null;
    //
    //   match /{document=**} {
    //     allow read, write: if request.auth != null;
    //   }
    // }
  }
}
