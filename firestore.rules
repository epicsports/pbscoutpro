rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Workspace document ──
    match /workspaces/{slug} {
      // Anyone authenticated can read workspace name (login screen check)
      allow read: if request.auth != null;
      // Anyone authenticated can create a new workspace
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'passwordHash', 'createdAt'])
                    && request.resource.data.members is list
                    && request.auth.uid in request.resource.data.members;
      // Only members can update
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.members;
      // Only admin can delete
      allow delete: if request.auth != null
                    && resource.data.adminUid == request.auth.uid;

      // ── All data inside a workspace ──
      // Only members of the workspace can read/write
      match /{document=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/workspaces/$(slug)).data.members;
      }
    }
  }
}
